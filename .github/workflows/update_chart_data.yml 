# .github/workflows/update_chart_data.yml
#
# Runs generate_chart_data.py on a schedule, commits the refreshed
# chart_data.json, and pushes it back to the repo — so GitHub Pages
# always serves the latest data without any manual intervention.

name: Update Chart Data

on:
  # ── Scheduled run — every Sunday at 03:00 UTC ──────────────────────────
  schedule:
    - cron: "0 3 * * 0"

  # ── Manual trigger from the GitHub Actions tab ─────────────────────────
  workflow_dispatch:

jobs:
  update-data:
    name: Fetch JSR data & regenerate chart_data.json
    runs-on: ubuntu-latest

    # Only push commits when running on the default branch
    # (prevents accidental writes from feature branches)
    if: github.ref == 'refs/heads/main' || github.event_name == 'workflow_dispatch'

    steps:

      # 1. Check out the full repository
      - name: Checkout repository
        uses: actions/checkout@v4

      # 2. Set up Python
      - name: Set up Python 3.11
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      # 3. Install Python dependencies
      - name: Install dependencies
        run: pip install requests

      # 4. Run the data pipeline
      - name: Run generate_chart_data.py
        run: python generate_chart_data.py

      # 5. Commit and push only if chart_data.json actually changed
      - name: Commit updated chart_data.json
        run: |
          git config user.name  "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add chart_data.json
          # Exit cleanly with code 0 if nothing changed (idempotent)
          git diff --cached --quiet && echo "No changes to commit." || \
            git commit -m "chore: auto-update chart_data.json [$(date -u '+%Y-%m-%d')]"

      # 6. Push back to the repository
      - name: Push changes
        uses: ad-m/github-push-action@v0.8.0
        with:
          github_token: ${{ secrets.GITHUB_TOKEN }}
          branch: main